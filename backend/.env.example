# Required runtime services
DATABASE_URL=postgresql+psycopg2://digest:digest@localhost:5432/digestit
REDIS_URL=redis://localhost:6379/0

# Optional AI key fallback. The Android app normally sends X-AI-Provider/X-API-Key
# headers per request, so these can stay empty. Fill them only if you want the
# backend to use server-side default keys when the app does not send one.
OPENAI_API_KEY=
CLAUDE_API_KEY=

AUDIO_TMP_DIR=/tmp/digestit_audio

# faster-whisper defaults: prefer NVIDIA GPU, then fall back to CPU automatically
WHISPER_MODEL=large-v3
WHISPER_DEVICE=cuda
WHISPER_COMPUTE_TYPE=float16

DEBUG=false
CORS_ALLOWED_ORIGINS_RAW=http://localhost,http://127.0.0.1,http://10.0.2.2:8000
